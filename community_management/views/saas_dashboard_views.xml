<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_saas_master_dashboard" model="ir.actions.act_window">
            <field name="name">Engagement &amp; Services Dashboard</field>
            <field name="res_model">saas.master.dashboard</field>
            <field name="view_mode">form</field>
            <field name="target">inline</field>
        </record>

        <menuitem id="menu_saas_master_dashboard" name="Master Dashboard" parent="menu_community_dashboard_root" sequence="0" action="action_saas_master_dashboard"/>

        <record id="view_saas_master_dashboard_form" model="ir.ui.view">
            <field name="name">saas.master.dashboard.form</field>
            <field name="model">saas.master.dashboard</field>
            <field name="arch" type="xml">
                <form string="SaaS Master Dashboard" create="false" edit="false">

                    <style>
                        :root {
                            --bg-color: #f1f5f9;
                            --card-bg: #ffffff;
                            --text-main: #0f172a;
                            --text-muted: #64748b;
                            --primary: #3b82f6;
                            --success: #10b981;
                            --warning: #f59e0b;
                            --border: #e2e8f0;
                        }
                        .saas-wrapper { background-color: var(--bg-color); padding: 30px; min-height: 100vh; font-family: 'Inter', -apple-system, sans-serif; }

                        /* HEADER */
                        .saas-header { background: #1e293b; color: white; border-radius: 24px; padding: 30px 40px; margin-bottom: 30px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.2); }
                        .filter-box { background: rgba(255,255,255,0.1); padding: 15px 25px; border-radius: 16px; border: 1px solid rgba(255,255,255,0.2); backdrop-filter: blur(10px); min-width: 350px; }
                        .filter-box .o_field_widget { font-weight: 800 !important; font-size: 1.2rem !important; color: white !important; }
                        .filter-box .o_input { background: transparent !important; color: white !important; border: none !important; }

                        /* CARDS */
                        .saas-card { background: var(--card-bg); border-radius: 20px; padding: 25px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02); border: 1px solid var(--border); transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s; height: 100%; position: relative; }
                        .saas-card:hover { transform: translateY(-5px); box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1); }

                        /* GRIDS */
                        .grid-kpi { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 25px; }
                        .grid-charts { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-bottom: 25px; }
                        .grid-activities { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }

                        /* TYPOGRAPHY */
                        .kpi-val { font-size: 2.8rem; font-weight: 900; color: var(--text-main); line-height: 1; margin-top: 15px; }
                        .kpi-label { font-size: 0.85rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; }
                        .kpi-icon { position: absolute; top: 25px; right: 25px; font-size: 2.5rem; opacity: 0.1; }
                        .section-title { font-size: 1.15rem; font-weight: 800; color: var(--text-main); margin-bottom: 20px; display: flex; align-items: center; gap: 10px; border-bottom: 2px solid #f1f5f9; padding-bottom: 15px; }
                    </style>

                    <div class="saas-wrapper">

                        <div class="saas-header">
                            <div>
                                <h1 style="font-weight: 900; margin: 0; font-size: 2.2rem; color:white !important;"><i class="fa fa-cubes text-primary mr-3"/> Workspace Hub</h1>
                                <p style="margin: 8px 0 0 0; color: #94a3b8; font-size: 1.1rem;">Engagement, Requests, &amp; Booking Management.</p>
                            </div>
                            <div class="filter-box">
                                <label for="community_id" style="color: #cbd5e1; font-size: 0.8rem; text-transform: uppercase; font-weight: 800; margin-bottom: 5px; display: block;">Target Community</label>
                                <field name="community_id" options="{'no_create': True}" placeholder="Select Community..."/>
                            </div>
                        </div>

                        <div invisible="not community_id">

                            <div class="grid-kpi">
                                <div class="saas-card" style="border-top: 4px solid var(--primary);">
                                    <i class="fa fa-bullhorn kpi-icon text-primary"/>
                                    <div class="kpi-label">Active Notices</div>
                                    <div class="kpi-val"><field name="active_notices"/></div>
                                </div>
                                <div class="saas-card" style="border-top: 4px solid #8b5cf6;">
                                    <i class="fa fa-id-card-o kpi-icon" style="color: #8b5cf6;"/>
                                    <div class="kpi-label">Total Access Requests</div>
                                    <div class="kpi-val"><field name="total_access_requests"/></div>
                                </div>
                                <div class="saas-card" style="border-top: 4px solid var(--warning);">
                                    <i class="fa fa-clock-o kpi-icon text-warning"/>
                                    <div class="kpi-label">Pending Access</div>
                                    <div class="kpi-val"><field name="pending_access"/></div>
                                </div>
                                <div class="saas-card" style="border-top: 4px solid var(--success);">
                                    <i class="fa fa-calendar-check-o kpi-icon text-success"/>
                                    <div class="kpi-label">Pending Bookings</div>
                                    <div class="kpi-val"><field name="pending_bookings"/></div>
                                </div>
                            </div>

                            <div class="grid-charts">
                                <div class="saas-card">
                                    <div class="section-title"><i class="fa fa-bar-chart text-primary"/> Notice Board Distribution</div>
                                    <field name="chart_notices" widget="html" nolabel="1"/>
                                </div>
                                <div class="saas-card">
                                    <div class="section-title"><i class="fa fa-pie-chart text-success"/> Amenity Booking Status</div>
                                    <field name="chart_bookings" widget="html" nolabel="1"/>
                                </div>
                            </div>

                            <div class="grid-activities">
                                <div class="saas-card">
                                    <div class="section-title"><i class="fa fa-bullhorn text-primary"/> Latest Announcements</div>
                                    <field name="recent_notices" widget="html" nolabel="1"/>
                                    <a href="/web#model=property.notice.board&amp;view_type=list" style="display: block; text-align: center; margin-top: 15px; color: var(--primary); font-weight: 800; text-decoration: none;">Manage Notices &amp;rarr;</a>
                                </div>

                                <div class="saas-card">
                                    <div class="section-title"><i class="fa fa-id-badge text-warning"/> Recent Access Requests</div>
                                    <field name="recent_requests" widget="html" nolabel="1"/>
                                    <a href="/web#model=resident.access.request&amp;view_type=list" style="display: block; text-align: center; margin-top: 15px; color: var(--warning); font-weight: 800; text-decoration: none;">Review Requests &amp;rarr;</a>
                                </div>

                                <div class="saas-card">
                                    <div class="section-title"><i class="fa fa-swimming-pool text-success"/> New Amenity Bookings</div>
                                    <field name="recent_bookings" widget="html" nolabel="1"/>
                                    <a href="/web#model=community.amenity.booking&amp;view_type=list" style="display: block; text-align: center; margin-top: 15px; color: var(--success); font-weight: 800; text-decoration: none;">View Bookings &amp;rarr;</a>
                                </div>
                            </div>

                        </div>
                    </div>
                </form>
            </field>
        </record>
    </data>
</odoo>
