<odoo>
    <data>
        <!-- Portal Page: Family Members List -->
        <template id="portal_family_member_form" name="Family Member Form">
            <t t-call="portal.portal_layout">
                <div class="container mt-4 mb-5">

                    <h2>
                        <t t-if="page_name == 'create_family_member'">Add Family Member</t>
                        <t t-if="page_name == 'edit_family_member'">Edit Family Member</t>
                    </h2>

                    <div class="card shadow-sm mt-3">
                        <div class="card-body">

                            <form method="post" enctype="multipart/form-data">

                                <!-- CSRF -->
                                <input type="hidden" name="csrf_token"
                                       t-att-value="request.csrf_token()"/>

                                <t t-if="page_name == 'create_family_member'">
                                    <input type="hidden" name="flat_id"
                                           t-att-value="flat.id"/>
                                </t>

                                <!-- PHOTO -->
                                <div class="form-group">
                                    <label>Photo</label>
                                    <input type="file" name="photo" class="form-control"/>
                                </div>

                                <!-- NAME -->
                                <div class="form-group">
                                    <label>Name *</label>
                                    <input type="text"
                                           name="name"
                                           class="form-control"
                                           required="required"
                                           t-att-value="member and member.name or ''"/>
                                </div>

                                <!-- MEMBER TYPE -->
                                <div class="form-group">
                                    <label>Member Type *</label>
                                    <select name="member_type"
                                            class="form-control"
                                            required="required">
                                        <option value="">Select Type</option>
                                        <t t-foreach="member_types" t-as="type">
                                            <option t-att-value="type[0]"
                                                    t-att-selected="member and member.member_type == type[0]">
                                                <t t-esc="type[1]"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>

                                <!-- GENDER -->
                                <div class="form-group">
                                    <label>Gender</label>
                                    <select name="gender" class="form-control">
                                        <option value="">Select Gender</option>
                                        <t t-foreach="genders" t-as="gender">
                                            <option t-att-value="gender[0]"
                                                    t-att-selected="member and member.gender == gender[0]">
                                                <t t-esc="gender[1]"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>

                                <!-- DATE OF BIRTH -->
                                <div class="form-group">
                                    <label>Date of Birth</label>
                                    <input type="date"
                                           name="date_of_birth"
                                           class="form-control"
                                           t-att-value="member and member.date_of_birth or ''"/>
                                </div>

                                <!-- RELATIONSHIP -->
                                <div class="form-group">
                                    <label>Relationship</label>
                                    <select name="relationship" class="form-control">
                                        <option value="">Select Relationship</option>
                                        <t t-foreach="relationships" t-as="rel">
                                            <option t-att-value="rel[0]"
                                                    t-att-selected="member and member.relationship == rel[0]">
                                                <t t-esc="rel[1]"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>

                                <!-- EMAIL -->
                                <div class="form-group">
                                    <label>Email</label>
                                    <input type="email"
                                           name="email"
                                           class="form-control"
                                           t-att-value="member and member.email or ''"/>
                                </div>

                                <!-- PHONE -->
                                <div class="form-group">
                                    <label>Phone</label>
                                    <input type="text"
                                           name="phone"
                                           class="form-control"
                                           t-att-value="member and member.phone or ''"/>
                                </div>

                                <!-- AADHAAR -->
                                <div class="form-group">
                                    <label>Aadhaar Number</label>
                                    <input type="text"
                                           name="aadhaar_number"
                                           maxlength="12"
                                           class="form-control"
                                           t-att-value="member and member.aadhaar_number or ''"/>
                                </div>

                                <!-- NOTES -->
                                <div class="form-group">
                                    <label>Notes</label>
                                    <textarea name="notes"
                                              class="form-control"
                                              rows="3">
                                        <t t-esc="member and member.notes or ''"/>
                                    </textarea>
                                </div>

                                <!-- BUTTONS -->
                                <div class="mt-4">
                                    <button type="submit" class="btn btn-primary">
                                        <t t-if="page_name == 'create_family_member'">Add Member</t>
                                        <t t-if="page_name == 'edit_family_member'">Update Member</t>
                                    </button>

                                    <a t-att-href="'/my/my-properties?property_id=%s' % (flat.id if flat else member.flat_id.id)"
                                       class="btn btn-secondary ml-2">
                                        Cancel
                                    </a>
                                </div>

                            </form>

                        </div>
                    </div>

                </div>
            </t>
        </template>
        <template id="portal_pet_form" name="Pet Form">
            <t t-call="portal.portal_layout">
                <div class="container mt-4 mb-5">

                    <h2>
                        <t t-if="page_name == 'create_pet'">Add Pet</t>
                        <t t-if="page_name == 'edit_pet'">Edit Pet</t>
                    </h2>

                    <div class="card shadow-sm mt-3">
                        <div class="card-body">

                            <form method="post" enctype="multipart/form-data">

                                <input type="hidden" name="csrf_token"
                                       t-att-value="request.csrf_token()"/>

                                <t t-if="page_name == 'create_pet'">
                                    <input type="hidden" name="flat_id"
                                           t-att-value="flat.id"/>
                                </t>

                                <!-- Photo -->
                                <div class="form-group">
                                    <label>Pet Photo</label>

                                    <t t-if="pet and pet.photo_1920">
                                        <div class="mb-2">
                                            <img t-att-src="'data:image/png;base64,%s' % pet.photo_1920"
                                                 style="width:150px;height:150px;object-fit:cover;border:2px solid #ddd;"/>
                                        </div>
                                    </t>

                                    <input type="file" name="photo" class="form-control"/>
                                </div>

                                <!-- Name -->
                                <div class="form-group">
                                    <label>Name *</label>
                                    <input type="text" name="name" class="form-control"
                                           required="required"
                                           t-att-value="pet and pet.name or ''"/>
                                </div>

                                <!-- Pet Type -->
                                <div class="form-group">
                                    <label>Pet Type</label>
                                    <select name="pet_type" class="form-control">
                                        <t t-foreach="pet_types" t-as="type">
                                            <option t-att-value="type[0]"
                                                    t-att-selected="pet and pet.pet_type == type[0]">
                                                <t t-esc="type[1]"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>

                                <!-- Breed -->
                                <div class="form-group">
                                    <label>Breed</label>
                                    <input type="text" name="breed"
                                           class="form-control"
                                           t-att-value="pet and pet.breed or ''"/>
                                </div>

                                <!-- Gender -->
                                <div class="form-group">
                                    <label>Gender</label>
                                    <select name="gender" class="form-control">
                                        <t t-foreach="genders" t-as="gender">
                                            <option t-att-value="gender[0]"
                                                    t-att-selected="pet and pet.gender == gender[0]">
                                                <t t-esc="gender[1]"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>

                                <!-- Age -->
                                <div class="form-group">
                                    <label>Age</label>
                                    <input type="number" name="age"
                                           class="form-control"
                                           t-att-value="pet and pet.age or ''"/>
                                </div>

                                <!-- Vaccinated -->
                                <div class="form-check mb-3">
                                    <input type="checkbox" name="vaccinated"
                                           class="form-check-input"
                                           t-att-checked="pet and pet.vaccinated"/>
                                    <label class="form-check-label">
                                        Vaccinated
                                    </label>
                                </div>

                                <!-- Notes -->
                                <div class="form-group">
                                    <label>Notes</label>
                                    <textarea name="notes" class="form-control">
                                        <t t-esc="pet and pet.notes or ''"/>
                                    </textarea>
                                </div>

                                <button type="submit" class="btn btn-primary">
                                    Save
                                </button>

                                <a t-att-href="'/my/my-properties?property_id=%s' % flat.id"
                                   class="btn btn-secondary">
                                    Cancel
                                </a>

                            </form>

                        </div>
                    </div>
                </div>
            </t>
        </template>


    </data>
</odoo>
