<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== ROOM VIEWS ==================== -->

    <record id="view_mygate_room_form" model="ir.ui.view">
        <field name="name">mygate.room.form</field>
        <field name="model">mygate.room</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_set_available" string="Mark as Available" type="object"
                            class="oe_highlight" invisible="state == 'available'"/>

                    <button name="action_set_maintenance" string="Put in Maintenance" type="object"
                            class="btn-warning" invisible="state != 'available'"/>

                    <button name="action_set_occupied" string="Mark as Occupied" type="object"
                            invisible="state != 'available'"/>

                    <field name="state" widget="statusbar" statusbar_visible="available,occupied,maintenance"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Room 101"/>
                        </h1>
                    </div>
                    <group>
                        <field name="room_type"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_mygate_room_list" model="ir.ui.view">
        <field name="name">mygate.room.list</field>
        <field name="model">mygate.room</field>
        <field name="arch" type="xml">
            <!-- Odoo 18: 'tree' tag renamed to 'list' (already used correctly) -->
            <list string="Rooms"
                  decoration-success="state == 'available'"
                  decoration-danger="state == 'occupied'">
                <field name="name"/>
                <field name="room_type"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'available'"
                       decoration-danger="state == 'occupied'"
                       decoration-warning="state == 'maintenance'"/>
            </list>
        </field>
    </record>

    <record id="action_mygate_room" model="ir.actions.act_window">
        <field name="name">Rooms</field>
        <field name="res_model">mygate.room</field>
        <field name="view_mode">list,form</field>
    </record>


    <!-- ==================== ROOM BOOKING VIEWS ==================== -->

    <record id="view_room_booking_form" model="ir.ui.view">
        <field name="name">mygate.room.booking.form</field>
        <field name="model">mygate.room.booking</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_request" string="Submit Request" type="object"
                            class="oe_highlight" invisible="state != 'draft'"/>

                    <button name="action_confirm_booking" string="Confirm Reservation" type="object"
                            class="btn-success" invisible="state != 'requested'"/>

                    <button name="action_checkout" string="Check Out" type="object"
                            class="oe_highlight" invisible="state != 'confirmed'"/>

                    <button name="action_cancel_booking" string="Cancel Booking" type="object"
                            class="btn-danger" invisible="state not in ['requested', 'confirmed']"/>

                    <button name="action_draft" string="Reset to Draft" type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,requested,confirmed,checked_out"/>

                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Member Details">
                            <field name="member_id"/>
                            <field name="check_in"/>
                            <field name="check_out"/>
                        </group>
                        <group string="Resort Coordination">
                            <field name="room_id" options="{'no_create': True}" required="state == 'requested'"/>

                            <field name="room_type" force_save="1" readonly="room_id != False"/>

                            <field name="cancellation_fee" invisible="state != 'cancelled'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Terms &amp; Conditions">
                            <field name="terms_conditions"
                                   placeholder="Select policy from dropdown..."/>
                        </page>
                    </notebook>
                </sheet>
                <!-- Odoo 18: Replaced oe_chatter div + manual fields with <chatter/> tag -->
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_mygate_room_booking_list" model="ir.ui.view">
        <field name="name">mygate.room.booking.list</field>
        <field name="model">mygate.room.booking</field>
        <field name="arch" type="xml">
            <list string="Room Bookings"
                  decoration-info="state == 'requested'"
                  decoration-success="state == 'confirmed'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="member_id"/>
                <field name="room_id"/>
                <field name="check_in"/>
                <field name="check_out"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'requested'"
                       decoration-success="state == 'confirmed'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="action_mygate_room_booking" model="ir.actions.act_window">
        <field name="name">Room Bookings</field>
        <field name="res_model">mygate.room.booking</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Raise your first room booking request!
            </p>
        </field>
    </record>


    <!-- ==================== MENU ITEMS ==================== -->

    <menuitem id="menu_mygate_room"
              name="Rooms"
              parent="menu_community_management_root"
              action="action_mygate_room"
              sequence="9"/>

    <menuitem id="menu_mygate_room_booking"
              name="Room Bookings"
              parent="menu_community_management_root"
              action="action_mygate_room_booking"
              sequence="10"/>

</odoo>
