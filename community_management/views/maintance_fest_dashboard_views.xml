<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_real_estate_dashboard" model="ir.actions.act_window">
            <field name="name">Financial &amp; Operations Dashboard</field>
            <field name="res_model">real.estate.dashboard</field>
            <field name="view_mode">form</field>
            <field name="target">inline</field>
        </record>

        <menuitem id="menu_real_estate_dashboard" name="Financial Operations" parent="menu_community_dashboard_root" sequence="1" action="action_real_estate_dashboard"/>

        <record id="view_real_estate_dashboard_form" model="ir.ui.view">
            <field name="name">real.estate.dashboard.form.premium</field>
            <field name="model">real.estate.dashboard</field>
            <field name="arch" type="xml">
                <form string="Financial Operations" create="false" edit="false">

                    <style>
                        :root {
                            --bg-color: #f8fafc;
                            --card-bg: #ffffff;
                            --text-main: #0f172a;
                            --text-muted: #64748b;
                            --primary: #3b82f6;
                            --success: #10b981;
                            --warning: #f59e0b;
                            --purple: #8b5cf6;
                            --border: #e2e8f0;
                        }
                        .saas-wrapper { background-color: var(--bg-color); padding: 30px; min-height: 100vh; font-family: 'Inter', -apple-system, sans-serif; }

                        /* HEADER */
                        .saas-header { background: #0f172a; color: white; border-radius: 24px; padding: 30px 40px; margin-bottom: 30px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.3); border-bottom: 5px solid var(--success);}
                        .filter-box { background: rgba(255,255,255,0.05); padding: 15px 25px; border-radius: 16px; border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(10px); min-width: 350px; }
                        .filter-box .o_field_widget { font-weight: 800 !important; font-size: 1.2rem !important; color: white !important; }
                        .filter-box .o_input { background: transparent !important; color: white !important; border: none !important; }

                        /* CARDS */
                        .saas-card { background: var(--card-bg); border-radius: 20px; padding: 25px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02); border: 1px solid var(--border); transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s; height: 100%; position: relative; }
                        .saas-card:hover { transform: translateY(-5px); box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1); }

                        /* GRIDS */
                        .grid-kpi { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 25px; }
                        .grid-charts { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-bottom: 25px; }
                        .grid-activities { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }

                        /* TYPOGRAPHY */
                        .kpi-val { font-size: 2.8rem; font-weight: 900; color: var(--text-main); line-height: 1; margin-top: 15px; }
                        .kpi-label { font-size: 0.85rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; }
                        .kpi-icon { position: absolute; top: 25px; right: 25px; font-size: 2.5rem; opacity: 0.1; }
                        .section-title { font-size: 1.15rem; font-weight: 800; color: var(--text-main); margin-bottom: 20px; display: flex; align-items: center; gap: 10px; border-bottom: 2px solid #f1f5f9; padding-bottom: 15px; }

                        .metric-small { display: flex; justify-content: space-between; font-weight: 700; font-size: 0.9rem; margin-bottom: 8px; color: var(--text-muted); }
                    </style>

                    <div class="saas-wrapper">

                        <div class="saas-header">
                            <div>
                                <h1 style="font-weight: 900; margin: 0; font-size: 2.2rem; color:white !important;"><i class="fa fa-line-chart text-success mr-3"/> Finance &amp; Properties</h1>
                                <p style="margin: 8px 0 0 0; color: #94a3b8 !important; font-size: 1.1rem;">Billing, Corpus Funds, and Occupancy tracking.</p>
                            </div>
                            <div class="filter-box">
                                <label for="community_id" style="color: #cbd5e1; font-size: 0.8rem; text-transform: uppercase; font-weight: 800; margin-bottom: 5px; display: block;">Target Community</label>
                                <field name="community_id" options="{'no_create': True}" placeholder="Select Community..."/>
                            </div>
                        </div>

                        <div invisible="not community_id">

                            <div class="grid-kpi">
                                <div class="saas-card" style="border-left: 5px solid var(--primary);">
                                    <i class="fa fa-building kpi-icon text-primary"/>
                                    <div class="kpi-label">Total Properties</div>
                                    <div class="kpi-val"><field name="total_flats_count"/></div>
                                </div>
                                <div class="saas-card" style="border-left: 5px solid var(--success);">
                                    <i class="fa fa-money kpi-icon text-success"/>
                                    <div class="kpi-label">Maintenance Collected</div>
                                    <div class="kpi-val" style="font-size: 2.2rem; margin-top: 22px;">₹<field name="collected_amount" widget="float" digits="[16,0]"/></div>
                                </div>
                                <div class="saas-card" style="border-left: 5px solid var(--purple);">
                                    <i class="fa fa-bank kpi-icon" style="color: var(--purple);"/>
                                    <div class="kpi-label">Corpus Fund Target</div>
                                    <div class="kpi-val" style="font-size: 2.2rem; margin-top: 22px;">₹<field name="total_corpus_fund_amount" widget="float" digits="[16,0]"/></div>
                                </div>
                                <div class="saas-card" style="border-left: 5px solid #ec4899;">
                                    <i class="fa fa-glass kpi-icon" style="color: #ec4899;"/>
                                    <div class="kpi-label">Planned Events</div>
                                    <div class="kpi-val"><field name="total_events_count"/></div>
                                </div>
                            </div>

                            <div class="grid-charts">
                                <div class="saas-card">
                                    <div class="section-title"><i class="fa fa-pie-chart text-primary"/> Occupancy &amp; Demographics</div>
                                    <field name="chart_occupancy_html" widget="html" nolabel="1"/>
                                    <div class="mt-4 pt-3 border-top">
                                        <div class="metric-small"><span><i class="fa fa-users text-info mr-2"/> Residents:</span> <span class="text-dark"><field name="total_residents_count"/></span></div>
                                        <div class="metric-small"><span><i class="fa fa-car text-secondary mr-2"/> Vehicles:</span> <span class="text-dark"><field name="total_vehicles_count"/></span></div>
                                        <div class="metric-small mb-0"><span><i class="fa fa-paw mr-2" style="color:#ec4899;"/> Pets:</span> <span class="text-dark"><field name="total_pets_count"/></span></div>
                                    </div>
                                </div>
                                <div class="saas-card">
                                    <div class="section-title"><i class="fa fa-bar-chart text-success"/> Maintenance Collection Flow</div>
                                    <field name="chart_finance_html" widget="html" nolabel="1"/>
                                    <div class="mt-4 pt-3 border-top">
                                        <div class="metric-small"><span><i class="fa fa-file-text-o text-muted mr-2"/> Total Bills Generated:</span> <span class="text-dark"><field name="total_maintenance_count"/></span></div>
                                        <div class="metric-small"><span><i class="fa fa-check-circle text-success mr-2"/> Confirmed Bills:</span> <span class="text-dark"><field name="confirmed_maintenance_count"/></span></div>
                                        <div class="metric-small mb-0"><span><i class="fa fa-clock-o text-warning mr-2"/> Draft Bills:</span> <span class="text-dark"><field name="pending_maintenance_count"/></span></div>
                                    </div>
                                </div>
                            </div>

                            <div class="grid-activities">
                                <div class="saas-card">
                                    <div class="section-title"><i class="fa fa-wrench text-primary"/> Recent Maintenance</div>
                                    <field name="feed_maintenance_html" widget="html" nolabel="1"/>
                                    <a href="/web#model=flat.maintenance&amp;view_type=list" style="display: block; text-align: center; margin-top: 15px; color: var(--primary); font-weight: 800; text-decoration: none;">View Billing &amp;rarr;</a>
                                </div>

                                <div class="saas-card">
                                    <div class="section-title"><i class="fa fa-bank" style="color: var(--purple);"/> Latest Corpus Invoices</div>
                                    <field name="feed_corpus_html" widget="html" nolabel="1"/>
                                    <a href="/web#model=corpus.fund.invoice&amp;view_type=list" style="display: block; text-align: center; margin-top: 15px; color: var(--purple); font-weight: 800; text-decoration: none;">Manage Funds &amp;rarr;</a>
                                </div>

                                <div class="saas-card">
                                    <div class="section-title"><i class="fa fa-calendar-star-o" style="color: #ec4899;"/> Upcoming Events</div>
                                    <field name="feed_events_html" widget="html" nolabel="1"/>
                                    <a href="/web#model=community.festival&amp;view_type=list" style="display: block; text-align: center; margin-top: 15px; color: #ec4899; font-weight: 800; text-decoration: none;">View Calendar &amp;rarr;</a>
                                </div>
                            </div>

                        </div>
                    </div>
                </form>
            </field>
        </record>
    </data>
</odoo>
