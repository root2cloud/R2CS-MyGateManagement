<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_membership_card_form" model="ir.ui.view">
        <field name="name">membership.card.request.form</field>
        <field name="model">membership.card.request</field>
        <field name="arch" type="xml">
            <form string="Membership Card Request">
                <header>
                    <button name="action_submit"
                            string="Submit Request"
                            type="object"
                            invisible="state != 'draft'"
                            class="btn-primary"/>

                    <button name="action_approve"
                            string="Approve"
                            type="object"
                            invisible="not can_approve"
                            class="btn-success"/>

                    <button name="action_reject"
                            string="Reject"
                            type="object"
                            invisible="not can_approve"
                            class="btn-danger"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,waiting_approval,issued"/>
                </header>
                <sheet>
                    <field name="can_approve" invisible="1"/>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Request Details">
                            <field name="member_id" readonly="state != 'draft'"/>
                            <field name="request_type" readonly="state != 'draft'"/>
                            <field name="reason"
                                   invisible="request_type == 'new'"
                                   required="request_type == 'reissue'"
                                   readonly="state != 'draft'"/>
                        </group>

                        <group string="Designated Approvers">
                            <field name="hod_user_id" readonly="state != 'draft'" options="{'no_create': True}"/>
                            <field name="md_user_id" readonly="state != 'draft'" options="{'no_create': True}"/>
                        </group>

                        <group string="Approval Status" invisible="state == 'draft'">
                            <field name="hod_approved" readonly="1"/>
                            <field name="md_approved" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_membership_card_request" model="ir.actions.act_window">
        <field name="name">Membership Card Requests</field>
        <field name="res_model">membership.card.request</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_membership_card_request"
              name="Card Requests"
              parent="menu_community_management_root"
              action="action_membership_card_request"
              sequence="10"/>
</odoo>
